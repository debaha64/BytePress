{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "SCH-000007",
  "title": "Role",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "ID": {
      "type": "string",
      "pattern": "^ROLE-[0-9]{6}$",
      "description": "Стабильный идентификатор сущности."
    },
    "Статус": {
      "type": "string",
      "description": "Текущее состояние сущности."
    },
    "Связи": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z]+-[0-9]{6}$"
      },
      "description": "Список идентификаторов связанных сущностей."
    },
    "Источник": {
      "type": "string",
      "description": "Основание появления сущности."
    },
    "Дата_создания": {
      "type": "string",
      "format": "date",
      "description": "Дата первого появления записи."
    },
    "Дата_изменения": {
      "type": "string",
      "format": "date",
      "description": "Дата последнего обновления записи."
    },
    "Название": {
      "type": "string",
      "minLength": 1,
      "description": "Краткое название сущности."
    },
    "Назначение": {
      "type": "string",
      "minLength": 1
    },
    "Допустимые_артефакты": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "Подключаемые_правила": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "Подключаемые_стандарты": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "Разрешённые_навыки": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "ID",
    "Название",
    "Статус",
    "Назначение",
    "Допустимые_артефакты",
    "Подключаемые_правила",
    "Подключаемые_стандарты",
    "Разрешённые_навыки",
    "Связи",
    "Источник",
    "Дата_создания",
    "Дата_изменения"
  ]
}
