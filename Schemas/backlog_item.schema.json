{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BacklogItem",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "ID": {
      "type": "string",
      "pattern": "^BACK-[0-9]{4}$",
      "description": "Стабильный идентификатор сущности."
    },
    "Статус": {
      "type": "string",
      "description": "Текущее состояние сущности."
    },
    "Связи": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z]+-[0-9]{4}$"
      },
      "description": "Список идентификаторов связанных сущностей."
    },
    "Источник": {
      "type": "string",
      "description": "Основание появления сущности."
    },
    "Дата_создания": {
      "type": "string",
      "format": "date",
      "description": "Дата первого появления записи."
    },
    "Дата_изменения": {
      "type": "string",
      "format": "date",
      "description": "Дата последнего обновления записи."
    },
    "Название": {
      "type": "string",
      "minLength": 1,
      "description": "Краткое название сущности."
    },
    "Тип": {
      "type": "string",
      "enum": [
        "Система",
        "Документация",
        "Стандарт",
        "Инструмент",
        "Продукт",
        "Исследование",
        "Инфраструктура",
        "Поддержка"
      ]
    },
    "Приоритет": {
      "type": "string",
      "enum": [
        "Низкий",
        "Средний",
        "Высокий",
        "Критический"
      ]
    },
    "Описание": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "ID",
    "Название",
    "Тип",
    "Приоритет",
    "Статус",
    "Описание",
    "Связи",
    "Источник",
    "Дата_создания",
    "Дата_изменения"
  ]
}
