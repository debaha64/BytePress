{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "SCH-000010",
  "title": "Term",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "ID": {
      "type": "string",
      "pattern": "^TERM-[0-9]{6}$",
      "description": "Стабильный идентификатор термина."
    },
    "Термин": {
      "type": "string",
      "minLength": 1,
      "description": "Нормативное имя термина."
    },
    "Статус": {
      "type": "string",
      "enum": [
        "Кандидат",
        "Принят",
        "Заменён",
        "Устарел",
        "Запрещён"
      ],
      "description": "Закрытое состояние термина."
    },
    "Область": {
      "type": "string",
      "minLength": 1,
      "description": "Область применения термина."
    },
    "Роль": {
      "type": "string",
      "minLength": 1,
      "description": "Роль термина в нормативном языке."
    },
    "Связи": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z]+-[0-9]{6}$"
      },
      "description": "Список идентификаторов связанных сущностей."
    },
    "Источник": {
      "type": "string",
      "minLength": 1,
      "description": "Основание появления или изменения термина."
    },
    "Дата_создания": {
      "type": "string",
      "format": "date",
      "description": "Дата первого появления карточки термина."
    },
    "Дата_изменения": {
      "type": "string",
      "format": "date",
      "description": "Дата последнего изменения карточки термина."
    },
    "Решение_по_конфликту": {
      "type": "string",
      "enum": [
        "Не_требуется",
        "Принять",
        "Заменить",
        "Запретить",
        "Оставить_кандидатом",
        "Существующий_термин_достаточен"
      ],
      "description": "Решение по терминологическому зазору или онтологическому конфликту."
    },
    "Определение": {
      "type": "string",
      "minLength": 1,
      "description": "Нормативное определение термина."
    },
    "Границы": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Ограничения и границы применения термина."
    },
    "Ключевые_характеристики": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Ключевые признаки термина."
    },
    "Недопустимые_синонимы": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Слова и выражения, которые нельзя использовать как синонимы термина."
    },
    "Связанные_термины": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^TERM-[0-9]{6}$"
      },
      "description": "Список связанных терминов."
    }
  },
  "required": [
    "ID",
    "Термин",
    "Статус",
    "Область",
    "Роль",
    "Связи",
    "Источник",
    "Дата_создания",
    "Дата_изменения",
    "Решение_по_конфликту",
    "Определение",
    "Границы",
    "Ключевые_характеристики",
    "Недопустимые_синонимы",
    "Связанные_термины"
  ]
}
