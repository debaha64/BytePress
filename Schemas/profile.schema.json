{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "SCH-000005",
  "title": "Profile",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "ID": {
      "type": "string",
      "pattern": "^PROF-[0-9]{6}$",
      "description": "Стабильный идентификатор сущности."
    },
    "Статус": {
      "type": "string",
      "description": "Текущее состояние сущности."
    },
    "Связи": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z]+-[0-9]{6}$"
      },
      "description": "Список идентификаторов связанных сущностей."
    },
    "Источник": {
      "type": "string",
      "description": "Основание появления сущности."
    },
    "Дата_создания": {
      "type": "string",
      "format": "date",
      "description": "Дата первого появления записи."
    },
    "Дата_изменения": {
      "type": "string",
      "format": "date",
      "description": "Дата последнего обновления записи."
    },
    "Название": {
      "type": "string",
      "minLength": 1,
      "description": "Краткое название сущности."
    },
    "Тип_профиля": {
      "type": "string",
      "enum": [
        "brand",
        "product"
      ]
    },
    "Бренд": {
      "type": "string",
      "minLength": 1
    },
    "Код_продукта": {
      "type": "string",
      "minLength": 1
    },
    "Язык_взаимодействия": {
      "type": "string",
      "minLength": 1
    },
    "Строгость": {
      "type": "string",
      "enum": [
        "Максимальная",
        "Средняя",
        "Низкая"
      ]
    },
    "Активный_путь": {
      "type": "string",
      "minLength": 1
    },
    "Активные_роли": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^ROLE-[0-9]{6}$"
      }
    },
    "Резервные_роли": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^ROLE-[0-9]{6}$"
      }
    },
    "Активные_правила": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^RULE-[0-9]{6}$"
      }
    },
    "Активные_стандарты": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^STD-[0-9]{6}$"
      }
    },
    "Активные_навыки": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^SKILL-[0-9]{6}$"
      }
    },
    "Активные_адаптеры": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^ADP-[0-9]{6}$"
      }
    },
    "Резервные_адаптеры": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^ADP-[0-9]{6}$"
      }
    }
  },
  "required": [
    "ID",
    "Название",
    "Статус",
    "Тип_профиля",
    "Бренд",
    "Язык_взаимодействия",
    "Строгость",
    "Активный_путь",
    "Активные_роли",
    "Резервные_роли",
    "Активные_правила",
    "Активные_стандарты",
    "Связи",
    "Источник",
    "Дата_создания",
    "Дата_изменения",
    "Резервные_адаптеры"
  ]
}
